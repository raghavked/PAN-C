# ============================================================
# PAN-C React Native (Expo Go)
# Environment Variables
# Copy to .env and fill in your values.
# EXPO_PUBLIC_ vars are embedded at build time (visible in bundle).
# ============================================================

# ── MongoDB Atlas ─────────────────────────────────────────────
# The Atlas Data API was permanently shut down on September 30, 2025.
# The current standard is the mongodb+srv:// connection string
# via the official MongoDB Node.js driver (v6+).
#
# How to get your connection string:
#   1. Go to cloud.mongodb.com → your cluster → Connect
#   2. Choose "Drivers" → Node.js → v5.5 or later
#   3. Copy the mongodb+srv:// URI shown and paste below
#
# ⚠️  SERVER-SIDE ONLY — never expose this in a mobile app bundle.
#     Use it only in your backend API server (Node.js/Express/Fastify).
#     The EXPO_PUBLIC_ prefix is intentionally omitted here.
#     The mobile app should call your backend API, not MongoDB directly.
#
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
MONGODB_DATABASE=pan_c

# ── Backend API ──────────────────────────────────────────────
# URL of your Node.js backend server that wraps MongoDB
# (e.g. deployed on Railway, Render, or a Replit backend Repl)
EXPO_PUBLIC_API_URL=https://your-backend.railway.app/api

# ── ElevenLabs ────────────────────────────────────────────────
EXPO_PUBLIC_ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Google Gemini ─────────────────────────────────────────────
EXPO_PUBLIC_GEMINI_API_KEY=<your-gemini-api-key>
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# ── Backboard.io (Long-Term Memory) ──────────────────────────
EXPO_PUBLIC_BACKBOARD_API_KEY=<your-backboard-api-key>
EXPO_PUBLIC_BACKBOARD_ASSISTANT_ID=<your-backboard-assistant-id>

# ── Solana ────────────────────────────────────────────────────
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
EXPO_PUBLIC_SOLANA_NETWORK=devnet
EXPO_PUBLIC_SOLANA_FUND_WALLET=<fund-wallet-public-key>

# ── Twilio (SMS Alerts) ───────────────────────────────────────
# ⚠️  Exposed in bundle — move to backend for production.
#     For now this enables SMS without a backend server.
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
EXPO_PUBLIC_TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
