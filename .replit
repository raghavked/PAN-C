run = "npm run dev"
entrypoint = "src/main.tsx"
modules = ["nodejs-20", "web", "nix"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["sh", "-c", "npm run build && npm run start"]
deploymentTarget = "cloudrun"
ignorePorts = false

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[env]
# The backend API URL — Replit automatically assigns a public HTTPS URL.
# After first deploy, replace this with your actual Replit app URL:
# VITE_API_URL = "https://<your-repl-name>.<your-username>.repl.co/api"
# For dev mode (both running in same Repl), use:
VITE_API_URL = "http://localhost:3001/api"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd rn && npx expo start --tunnel --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd server && npm install --silent 2>/dev/null; node src/index.js"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
DOCUMENT_ENCRYPTION_KEY = "505d68f19705b2c9534d2830dab38012c731908991856d1bfb63b8335b1d8418"
