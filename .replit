run = "npm run dev"
entrypoint = "src/main.tsx"
modules = ["nodejs-20", "web", "nix"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["sh", "-c", "npm run build && npm run start"]
deploymentTarget = "cloudrun"
ignorePorts = false

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[env]
# The backend API URL — Replit automatically assigns a public HTTPS URL.
# After first deploy, replace this with your actual Replit app URL:
# VITE_API_URL = "https://<your-repl-name>.<your-username>.repl.co/api"
# For dev mode (both running in same Repl), use:
VITE_API_URL = "http://localhost:3001/api"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd rn && npx expo start --port 8080"
waitForPort = 8080
