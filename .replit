modules = ["nodejs-20"]
[core]
entrypoint = "index.js"

[nix]
channel = "stable-24.05"

[env]
REPLIT_LANGUAGE = "nodejs"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5001
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd server && npm install --silent 2>/dev/null; node src/index.js"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd rn && npx expo install --silent 2>/dev/null; npx expo start --tunnel --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
