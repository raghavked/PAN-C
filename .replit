run = "npm run dev"
entrypoint = "src/main.tsx"
modules = ["nodejs-20", "web", "nix"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["sh", "-c", "npm run build && npm run preview"]
deploymentTarget = "cloudrun"
ignorePorts = false

[[ports]]
localPort = 3000
externalPort = 80

[env]
VITE_API_URL = "http://localhost:3000/api"
