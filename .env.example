# ============================================================
# PAN-C — ICE Panic Button
# Environment Variables
# Copy this file to .env and fill in your values.
# In Replit: add each key in the Secrets tab (🔒).
# ============================================================

# ── App Config ───────────────────────────────────────────────
VITE_APP_NAME=ICE Panic Button
VITE_APP_VERSION=1.0.0

# ── Backend API ──────────────────────────────────────────────
# Base URL for the PAN-C backend (panic trigger, disarm, check-in)
VITE_API_URL=http://localhost:3000/api

# ── MongoDB Atlas Data API ───────────────────────────────────
# Stores incidents, contacts, and document metadata
# Setup: MongoDB Atlas → App Services → Data API → Enable
VITE_MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/<YOUR-APP-ID>/endpoint/data/v1
VITE_MONGODB_API_KEY=<your-mongodb-data-api-key>
VITE_MONGODB_DATABASE=pan_c
VITE_MONGODB_DATA_SOURCE=Cluster0

# ── ElevenLabs ───────────────────────────────────────────────
# AI voice for the "HELP — ICE / MIGRA" panic audio alert
# Setup: elevenlabs.io → Profile → API Keys
VITE_ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
# Optional: override the default voice (Rachel = 21m00Tcm4TlvDq8ikWAM)
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Google Gemini ─────────────────────────────────────────────
# AI-powered legal rights guidance, incident summaries, translation
# Setup: aistudio.google.com → Get API Key
VITE_GEMINI_API_KEY=<your-gemini-api-key>
# Optional: override model (default: gemini-2.0-flash)
VITE_GEMINI_MODEL=gemini-2.0-flash

# ── Blackboard Learn (Anthology) ─────────────────────────────
# LMS integration — push emergency announcements to enrolled course communities
# Setup:
#   1. Register at developer.blackboard.com → create Application → get Key + Secret
#   2. Install Application ID on your Learn instance: Admin → REST API Integrations
#   3. Add Key + Secret below
# Docs: https://docs.anthology.com/docs/blackboard/rest-apis/start-here
VITE_BLACKBOARD_BASE_URL=https://yourschool.blackboard.com
VITE_BLACKBOARD_APP_KEY=<your-blackboard-application-key>
VITE_BLACKBOARD_APP_SECRET=<your-blackboard-application-secret>
# Course ID to post emergency announcements to (from your Learn instance)
VITE_BLACKBOARD_COURSE_ID=<your-course-id>

# ── Solana ────────────────────────────────────────────────────
# On-chain incident logging + community legal aid fund donations
# RPC: use devnet for testing, mainnet-beta for production
# Recommended RPC providers: Helius (helius.xyz) or QuickNode
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_NETWORK=devnet
# Public key of the community legal aid fund wallet (no private keys here!)
VITE_SOLANA_FUND_WALLET=<fund-wallet-public-key>

# ── Feature Flags ─────────────────────────────────────────────
VITE_ENABLE_AUDIO=true
VITE_ENABLE_LOCATION=true
VITE_ENABLE_NOTIFICATIONS=true
