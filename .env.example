# ============================================================
# PAN-C — ICE Panic Button
# Environment Variables
# Copy this file to .env and fill in your values.
# In Replit: add each key in the Secrets tab (🔒).
# ============================================================

# ── App Config ───────────────────────────────────────────────
VITE_APP_NAME=ICE Panic Button
VITE_APP_VERSION=1.0.0

# ── Backend API ──────────────────────────────────────────────
# Base URL for the PAN-C backend (panic trigger, disarm, check-in)
VITE_API_URL=http://localhost:3000/api

# ── MongoDB Atlas ─────────────────────────────────────────────
# The Atlas Data API was permanently shut down on September 30, 2025.
# The current standard is the mongodb+srv:// connection string
# via the official MongoDB Node.js driver (v6+).
#
# How to get your connection string:
#   1. Go to cloud.mongodb.com → your cluster → Connect
#   2. Choose "Drivers" → Node.js → v5.5 or later
#   3. Copy the mongodb+srv:// URI shown and paste below
#
# ⚠️  SERVER-SIDE ONLY — never expose this in frontend/browser code.
#     Use it only in your backend API server (Node.js/Express/Fastify).
#     This key intentionally does NOT use the VITE_ prefix.
#
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
MONGODB_DATABASE=pan_c

# ── ElevenLabs ───────────────────────────────────────────────
# AI voice for the "HELP — ICE / MIGRA" panic audio alert
# Setup: elevenlabs.io → Profile → API Keys
VITE_ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
# Optional: override the default voice (Rachel = 21m00Tcm4TlvDq8ikWAM)
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Google Gemini ─────────────────────────────────────────────
# AI-powered legal rights guidance, incident summaries, translation
# Setup: aistudio.google.com → Get API Key
VITE_GEMINI_API_KEY=<your-gemini-api-key>
# Optional: override model (default: gemini-2.0-flash)
VITE_GEMINI_MODEL=gemini-2.0-flash

# ── Backboard.io (Long-Term Memory) ──────────────────────────
# Persistent AI memory — remembers user preferences, past incidents,
# emergency contacts, and legal notes across all sessions
# Setup: app.backboard.io → Settings → API Keys → Create New API Key
VITE_BACKBOARD_API_KEY=<your-backboard-api-key>
# Assistant ID — create one assistant per user (or one shared PAN-C assistant)
# Get from: app.backboard.io → Assistants → create assistant → copy ID
VITE_BACKBOARD_ASSISTANT_ID=<your-backboard-assistant-id>

# ── Solana ────────────────────────────────────────────────────
# On-chain incident logging + community legal aid fund donations
# RPC: use devnet for testing, mainnet-beta for production
# Recommended RPC providers: Helius (helius.xyz) or QuickNode
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_NETWORK=devnet
# Public key of the community legal aid fund wallet (no private keys here!)
VITE_SOLANA_FUND_WALLET=<fund-wallet-public-key>

# ── Twilio (SMS Alerts) ──────────────────────────────────────
# Sends real SMS to emergency contacts on panic trigger, disarm, and check-in
# Setup: console.twilio.com → Account Info (top of dashboard)
# ⚠️  These are exposed in the browser bundle (Option A).
#     For production, move to a backend server (Option B).
VITE_TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
VITE_TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
VITE_TWILIO_PHONE_NUMBER=<your-twilio-from-number>  # e.g. +15551234567

# ── Feature Flags ─────────────────────────────────────────────
VITE_ENABLE_AUDIO=true
VITE_ENABLE_LOCATION=true
VITE_ENABLE_NOTIFICATIONS=true
