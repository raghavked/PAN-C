{
  "name": "panic-app",
  "version": "1.0.0",
  "description": "PAN!C — Personal Alert Network · Interactive Crisis Communication",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"red,cyan\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --port 5000 --host 0.0.0.0",
    "dev:server": "cd server && node src/index.js",
    "build": "tsc && vite build",
    "start": "bash start.sh",
    "start:client": "vite preview --port 5000 --host 0.0.0.0",
    "start:server": "cd server && node src/index.js",
    "install:all": "npm install && cd server && npm install && cd rn && npm install",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
