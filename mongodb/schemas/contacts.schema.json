{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "PAN-C Emergency Contact",
    "description": "An emergency contact who will be notified when the panic button is triggered",
    "required": ["contactId", "userId", "name", "priority", "createdAt", "updatedAt"],
    "additionalProperties": false,
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "contactId": {
        "bsonType": "string",
        "description": "Unique contact identifier (UUID v4)"
      },
      "userId": {
        "bsonType": "string",
        "description": "Owner user's ID — foreign key to users collection"
      },
      "name": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Full name of the emergency contact"
      },
      "relationship": {
        "bsonType": "string",
        "maxLength": 50,
        "description": "Relationship to the user (e.g. Mom, Lawyer, Brother)",
        "enum": [
          "Family",
          "Spouse/Partner",
          "Parent",
          "Sibling",
          "Child",
          "Friend",
          "Lawyer",
          "Legal Aid",
          "Employer",
          "Community Org",
          "Other"
        ]
      },
      "phone": {
        "bsonType": "string",
        "pattern": "^\\+[1-9]\\d{1,14}$",
        "description": "E.164 format phone number for SMS alerts"
      },
      "email": {
        "bsonType": "string",
        "pattern": "^[^@]+@[^@]+\\.[^@]+$",
        "description": "Email address for email alerts"
      },
      "notifyMethods": {
        "bsonType": "array",
        "description": "Which channels to use when notifying this contact",
        "items": {
          "bsonType": "string",
          "enum": ["SMS", "Email", "Push"]
        },
        "minItems": 1
      },
      "priority": {
        "bsonType": "int",
        "minimum": 1,
        "maximum": 10,
        "description": "Notification priority order — 1 is highest priority"
      },
      "isActive": {
        "bsonType": "bool",
        "description": "Whether this contact is currently active and will receive alerts",
        "default": true
      },
      "notes": {
        "bsonType": "string",
        "maxLength": 500,
        "description": "Optional notes about this contact (e.g. best time to call, language)"
      },
      "createdAt": {
        "bsonType": "date"
      },
      "updatedAt": {
        "bsonType": "date"
      }
    }
  }
}
